{
  "name": "cesium-nextjs-starter-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-cesium": "cpx \"node_modules/cesium/Build/Cesium/**/*\" public/cesium",
    "dev": "npm run copy-cesium && next dev --turbopack",
    "build": "npm run copy-cesium && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "postinstall": "npm run copy-cesium"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "cesium": "^1.137.0",
    "clsx": "^2.1.1",
    "maplibre-gl": "^5.22.0",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resium": "^1.19.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/maplibre-gl": "^1.13.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cpx2": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3"
  }
}
